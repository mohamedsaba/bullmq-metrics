{
  "name": "bullmq-metrics",
  "version": "1.0.0",
  "description": "Zero-configuration metrics exporter for BullMQ in NestJS/Node.js environments",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:e2e": "jest tests/e2e",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "keywords": [
    "bullmq",
    "prometheus",
    "metrics",
    "nestjs",
    "monitoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.15",
    "bullmq": "^5.76.2",
    "ioredis": "^5.4.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "peerDependencies": {
    "bullmq": "^5.0.0"
  }
}

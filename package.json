{
  "name": "@mohamedsaba/bullmq-metrics",
  "version": "1.2.0",
  "description": "Zero-configuration Prometheus metrics exporter for BullMQ in NestJS/Node.js environments",
  "author": "Mohamed Saba",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohamedsaba/bullmq-metrics"
  },
  "homepage": "https://github.com/mohamedsaba/bullmq-metrics#readme",
  "bugs": {
    "url": "https://github.com/mohamedsaba/bullmq-metrics/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "rimraf dist .tsbuildinfo && tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:e2e": "jest tests/e2e",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bullmq",
    "prometheus",
    "metrics",
    "nestjs",
    "monitoring",
    "queue",
    "redis",
    "prom-client",
    "observability"
  ],
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "bullmq": "^5.0.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": false
    },
    "@nestjs/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.10",
    "bullmq": "^5.0.0",
    "ioredis": "^5.4.1",
    "jest": "^29.7.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
